# ===================================================================
# Hounslow Bin Collection - Configuration Example
# ===================================================================
# Copy this file to config.yaml and modify with your address details
#
# Environment Variables Override:
# You can also set these via environment variables:
# - HOUNSLOW_POSTCODE="TW7 4QQ"
# - HOUNSLOW_ADDRESS="123 Your Street"

# ===================================================================
# APPLICATION SETTINGS
# ===================================================================
app:
  name: "hounslow_bin_collection"
  version: "0.1.0"
  debug: false

# ===================================================================
# YOUR ADDRESS CONFIGURATION
# ===================================================================
# Configure your address for bin collection lookup:
# Uses enhanced browser automation with intelligent address matching

address:
  # Your postcode (required)
  postcode: "TW3 3EB"

  # Your address hint (required)
  # Can be partial - the system will find the best match
  address_hint: "7 Bath Rd"# ===================================================================
# SMART ADDRESS MATCHING INFO
# ===================================================================
# The enhanced address matching system automatically handles:
# ✅ Abbreviations: Rd → Road, St → Street, Ave → Avenue, etc.
# ✅ Partial addresses: house numbers, street names only
# ✅ Case variations and formatting differences
# ✅ Building names: libraries, schools, council buildings
#
# Examples that work:
# - "7 Bath Rd" → matches "7 Bath Road"
# - "136 Worple Rd" → matches "136 Worple Road"
# - "Bath Road" → matches "7 Bath Road" (if unique)
# - "Hounslow Library" → matches "Centre Space Hounslow Library"
#
# Manual verification: https://my.hounslow.gov.uk/service/Waste_and_recycling_collections

# ===================================================================
# EXAMPLE CONFIGURATIONS
# ===================================================================
# Here are some real-world examples to help you configure your address:

examples:
  # Example 1: Using house number + abbreviated street name
  residential_abbreviated:
    postcode: "TW7 7HX"
    address_hint: "136 Worple Rd"
    description: "Common format - house number with abbreviated street"

  # Example 2: Using full street name only
  street_name_only:
    postcode: "TW3 3EB"
    address_hint: "Bath Road"
    description: "Street name only - system finds house number"

  # Example 3: Building/landmark name
  landmark_building:
    postcode: "TW3 1ES"
    address_hint: "Hounslow Library"
    description: "Building name - system handles full address"

  # Example 4: Flat/apartment address
  flat_address:
    postcode: "TW4 6JH"
    address_hint: "Flat 12A High Street"
    description: "Apartment with unit number"# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
logging:
  level: "INFO" # DEBUG, INFO, WARNING, ERROR
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  file: null # Set to filename to log to file (e.g., "hounslow_collection.log")

# ===================================================================
# BROWSER AUTOMATION SETTINGS
# ===================================================================
browser:
  # Run browser in headless mode (no visible window)
  headless: true

  # Timeout for browser operations (milliseconds)
  timeout: 30000

  # Save screenshots when errors occur (helpful for debugging)
  screenshot_on_error: true

  # Browser viewport size
  viewport:
    width: 1280
    height: 720

# ===================================================================
# APPLICATION BEHAVIOR
# ===================================================================
settings:
  # General timeout for operations (seconds)
  timeout: 30

  # Number of retry attempts for failed operations
  retry_count: 3

  # Batch processing size (for multiple addresses)
  batch_size: 10

# ===================================================================
# RATE LIMITING (Be respectful to council servers)
# ===================================================================
rate_limiting:
  # Enable rate limiting to avoid overwhelming the server
  enabled: true

  # Minimum delay between requests (seconds)
  min_delay_seconds: 5

  # Maximum requests per hour
  max_requests_per_hour: 10

  # Respect robots.txt and server load
  respectful_mode: true
