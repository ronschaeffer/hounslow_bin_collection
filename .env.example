# Hounslow Bin Collection Calendar Configuration
# Copy this file to .env and edit it with your details.

# --- REQUIRED SETTINGS ---
UPRN=100021577775

# --- MQTT SETTINGS (Required if MQTT_ENABLED is true) ---
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USERNAME=YOUR_MQTT_USERNAME
MQTT_PASSWORD=YOUR_MQTT_PASSWORD

# --- FEATURE TOGGLES ---
MQTT_ENABLED=true

# --- OPTIONAL SETTINGS ---
# The host port for the built-in web server that serves the .ics file.
ICS_PORT=8208
# The cron schedule for running the sync.
CRON_SCHEDULE=50 2 * * *
# Your local timezone, e.g., Europe/London
TZ=Europe/London
