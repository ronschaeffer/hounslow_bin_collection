# Hounslow Bin Collection Calendar Configuration
# Copy this file to .env and edit with your details.

# --- REQUIRED SETTINGS ---
# Use browser automation with enhanced address matching (RECOMMENDED - WORKING)
HOUNSLOW_POSTCODE=TW3 3EB
HOUNSLOW_ADDRESS=7 Bath Rd

# Legacy UPRN method (currently blocked by council API security)
# UPRN=100021577775

# For address lookup, visit: https://my.hounslow.gov.uk/service/Waste_and_recycling_collections

# --- MQTT SETTINGS (Required if MQTT_ENABLED is true) ---
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USERNAME=YOUR_MQTT_USERNAME
MQTT_PASSWORD=YOUR_MQTT_PASSWORD

# --- FEATURE TOGGLES ---
MQTT_ENABLED=true

# --- OPTIONAL SETTINGS ---
# The host port for the built-in web server that serves the .ics file.
ICS_PORT=8208
# The cron schedule for running the sync.
CRON_SCHEDULE=50 2 * * *
# Your local timezone, e.g., Europe/London
TZ=Europe/London
