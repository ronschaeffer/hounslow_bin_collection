# ===================================================================
# Hounslow Bin Collection - Environment Configuration Example
# ===================================================================
# Copy this file to .env and edit with your specific details
# This file shows example values - customize for your setup

# ===================================================================
# YOUR ADDRESS CONFIGURATION
# ===================================================================
# Required: Configure your address for bin collection lookup
# These override config.yaml settings when provided

# Your postcode (required)
HOUNSLOW_POSTCODE=TW3 3EB

# Your address hint - can be partial, system will find best match
# Examples: "7 Bath Rd", "136 Worple Road", "Hounslow Library"
HOUNSLOW_ADDRESS=7 Bath Rd

# ===================================================================
# MQTT INTEGRATION SETTINGS
# ===================================================================
# Enable/disable MQTT publishing of collection data
MQTT_ENABLED=true

# MQTT broker connection details (required if MQTT_ENABLED=true)
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883

# MQTT authentication (optional - leave blank if no auth required)
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# ===================================================================
# APPLICATION SETTINGS
# ===================================================================
# Web server port for serving calendar files (.ics)
ICS_PORT=8208

# Cron schedule for automatic collection data sync
# Format: minute hour day month day_of_week
# Default: 2:50 AM daily
CRON_SCHEDULE=50 2 * * *

# Local timezone for scheduling and date handling
TZ=Europe/London

# ===================================================================
# BROWSER AUTOMATION SETTINGS
# ===================================================================
# Run browser in headless mode (recommended for production)
BROWSER_HEADLESS=true

# Browser operation timeout (milliseconds)
BROWSER_TIMEOUT=30000

# Enable debug screenshots on errors
BROWSER_DEBUG_SCREENSHOTS=false

# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log to file (optional - leave blank to log to console only)
LOG_FILE=

# ===================================================================
# RATE LIMITING (Be respectful to council servers)
# ===================================================================
# Minimum delay between requests (seconds)
MIN_REQUEST_DELAY=5

# Maximum requests per hour
MAX_REQUESTS_PER_HOUR=10
