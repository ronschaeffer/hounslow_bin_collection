#!/bin/bash
# Convenience script for Hounslow bin collection lookup

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_VENV="$SCRIPT_DIR/.venv/bin/python"
CLI_SCRIPT="$SCRIPT_DIR/bin_lookup.py"

# Check if virtual environment exists
if [[ ! -f "$PYTHON_VENV" ]]; then
    echo "❌ Error: Python virtual environment not found at $PYTHON_VENV"
    echo "💡 Tip: Run 'poetry install' or set up the virtual environment first"
    exit 1
fi

# Check if CLI script exists
if [[ ! -f "$CLI_SCRIPT" ]]; then
    echo "❌ Error: CLI script not found at $CLI_SCRIPT"
    exit 1
fi

# Run the CLI with all arguments passed through
"$PYTHON_VENV" "$CLI_SCRIPT" "$@"
